{
  "name": "glyphloop",
  "private": true,
  "version": "0.1.0-beta.0",
  "description": "Create loop-perfect ASCII animations in a browser or through a CLI and MCP server.",
  "license": "MIT",
  "author": "Grant Brown",
  "homepage": "https://glyphloop.art",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ideoshi/glyphloop.git"
  },
  "bugs": {
    "url": "https://github.com/ideoshi/glyphloop/issues"
  },
  "keywords": [
    "ascii-art",
    "animation",
    "creative-coding",
    "mcp",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "mcpName": "io.github.ideoshi/glyphloop",
  "type": "module",
  "bin": {
    "glyphloop": "bin/glyphloop.js"
  },
  "files": [
    "bin",
    "presets",
    "src/cli",
    "src/core",
    "src/export/embed.ts",
    "src/export/frames.ts",
    "src/export/terminal.ts",
    "src/mcp",
    "src/presets",
    "src/sources",
    "src/version.ts",
    "AGENTS.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "LICENSES/ASSETS.md",
    "README.md",
    "SECURITY.md",
    "TRADEMARKS.md"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:site": "tsc --noEmit && node scripts/build-site.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "verify:package": "node scripts/verify-package.mjs",
    "verify:public-snapshot": "node scripts/verify-public-snapshot.mjs",
    "waitlist:export": "node scripts/export-waitlist.mjs",
    "render": "tsx src/cli/render.ts",
    "mcp": "tsx src/mcp/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "tsx": "^4.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "gifenc": "^1.0.3",
    "mp4-muxer": "^5.2.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0",
    "wrangler": "4.110.0"
  }
}
